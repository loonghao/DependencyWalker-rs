// Modern theme and style definitions for DependencyWalker RS
// This file defines the color palette, typography, and spacing system

export global Theme {
    // Modern color palette
    in-out property <color> primary: #007AFF;
    in-out property <color> primary-hover: #0056D6;
    in-out property <color> secondary: #616161;
    in-out property <color> accent: #AB47FF;
    
    // Background colors for modern design
    in-out property <color> background-primary: #141414;
    in-out property <color> background-secondary: #1F1F1F;
    in-out property <color> background-tertiary: #292929;
    
    // Text colors
    in-out property <color> text-primary: #F2F2F2;
    in-out property <color> text-secondary: #B3B3B3;
    in-out property <color> text-muted: #808080;
    
    // Status colors with modern palette
    in-out property <color> success: #00CC66;
    in-out property <color> warning: #FF9900;
    in-out property <color> error: #FF3B30;
    in-out property <color> info: #007AFF;
    
    // Dependency status colors
    in-out property <color> found: #00CC66;
    in-out property <color> missing: #FF3B30;
    in-out property <color> system-dll: #80B3FF;
    in-out property <color> delayed: #FF9900;
    in-out property <color> mll-plugin: #CC66FF;
    
    // Border and separator colors
    in-out property <color> border: #404040;
    in-out property <color> border-focus: #007AFF;
    in-out property <color> separator: #333333;
    
    // Spacing system based on 2px grid - Ultra compact
    in-out property <length> spacing-tiny: 1px;
    in-out property <length> spacing-small: 2px;
    in-out property <length> spacing-medium: 3px;
    in-out property <length> spacing-large: 4px;
    in-out property <length> spacing-extra-large: 6px;
    in-out property <length> spacing-huge: 8px;
    in-out property <length> spacing-massive: 12px;

    // Typography scale - More compact
    in-out property <length> font-caption: 10px;
    in-out property <length> font-small: 11px;
    in-out property <length> font-body: 12px;
    in-out property <length> font-medium: 13px;
    in-out property <length> font-large: 14px;
    in-out property <length> font-heading: 15px;
    in-out property <length> font-title: 16px;
    in-out property <length> font-display: 20px;
    
    // Border radius for modern design
    in-out property <length> radius-small: 4px;
    in-out property <length> radius-medium: 8px;
    in-out property <length> radius-large: 12px;
    in-out property <length> radius-round: 50px;
}

// File type icons and colors
export global FileTypes {
    public pure function get-icon(extension: string) -> string {
        if (extension == "exe") { "▶" }
        else if (extension == "dll") { "⚙" }
        else if (extension == "sys") { "⚡" }
        else if (extension == "ocx") { "◆" }
        else if (extension == "mll") { "★" }
        else { "◯" }
    }

    public pure function get-color(extension: string) -> color {
        if (extension == "exe") { Theme.primary }
        else if (extension == "dll") { Theme.success }
        else if (extension == "sys") { Theme.warning }
        else if (extension == "ocx") { Theme.info }
        else if (extension == "mll") { Theme.mll-plugin }
        else { Theme.text-muted }
    }

    public pure function get-description(extension: string) -> string {
        if (extension == "exe") { "Executable File" }
        else if (extension == "dll") { "Dynamic Link Library" }
        else if (extension == "sys") { "System Driver" }
        else if (extension == "ocx") { "ActiveX Control" }
        else if (extension == "mll") { "Maya Plugin Library" }
        else { "Unknown File Type" }
    }
}

// Common button styles
export component ModernButton inherits Rectangle {
    in property <string> text;
    in property <color> button-background: Theme.primary;
    in property <color> text-color: Theme.text-primary;
    in property <bool> button-enabled: true;

    callback clicked;

    background: root.button-enabled ? (touch-area.has-hover ? root.button-background.darker(0.1) : root.button-background) : Theme.secondary;
    border-radius: Theme.radius-medium;

    touch-area := TouchArea {
        width: 100%;
        height: 100%;

        clicked => {
            if (root.button-enabled) {
                root.clicked();
            }
        }
    }

    Text {
        text: root.text;
        color: root.text-color;
        font-size: Theme.font-body;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Modern container with border
export component ModernContainer inherits Rectangle {
    in property <color> background-color: Theme.background-secondary;
    in property <bool> has-border: true;
    
    background: background-color;
    border-radius: Theme.radius-medium;
    border-width: has-border ? 1px : 0px;
    border-color: Theme.border;
}
